<?xml version="1.0" encoding="utf-8"?>
<style xmlns="http://purl.org/net/xbiblio/csl"
       class="note"
       version="1.0"
       default-locale="fr-CH"
       page-range-format="expanded"
       delimiter-precedes-et-al="always"
       delimiter-precedes-last="never"
       et-al-min="5"
       et-al-use-first="3">

  <info>
    <title>UNIL Cinéma – notes et bibliographie (2025-2026 v. 1.3)</title>
    <title-short>UNIL Cinéma</title-short>
    <id>http://www.zotero.org/styles/unil-cinema-notes-biblio-fr-ch</id>
    <link href="http://www.zotero.org/styles/unil-cinema-notes-biblio-fr-ch" rel="self"/>
    <author>
      <name>Assisté par ChatGPT à partir du style d’André J. S. Fonseca</name>
    </author>
    <category citation-format="note"/>
    <category field="history"/>
    <category field="cinema"/>
    <summary>Style notes-bibliographie adapté aux consignes 2025/2026 de la Section d’histoire et esthétique du cinéma de l’UNIL.</summary>
    <updated>2026-03-23T00:00:00+00:00</updated>
    <rights license="http://creativecommons.org/licenses/by-sa/3.0/"/>
  </info>

  <locale xml:lang="fr">
    <terms>
      <term name="editor" form="short">dir.</term>
      <term name="page" form="short">p.</term>
      <term name="page" form="short" plural="true">pp.</term>
      <term name="ibid">Idem.</term>
      <term name="loc-cit">Ibid.</term>
      <term name="cited">op. cit.</term>
    </terms>
  </locale>

  <!-- ========================= -->
  <!-- AUTHOR -->
  <!-- ========================= -->

  <macro name="author-note">
    <names variable="author">
      <name and="text"/>
    </names>
  </macro>

  <macro name="author-bib">
    <names variable="author">
      <name name-as-sort-order="all">
        <name-part name="family" text-case="uppercase"/>
      </name>
    </names>
  </macro>

  <!-- ========================= -->
  <!-- DATE -->
  <!-- ========================= -->

  <macro name="year">
    <choose>
      <if variable="issued">
        <date variable="issued">
          <date-part name="year"/>
        </date>
      </if>
      <else>
        <text value="[s.d.]"/>
      </else>
    </choose>
  </macro>

  <!-- ========================= -->
  <!-- TITLE -->
  <!-- ========================= -->

  <macro name="title">
    <choose>
      <if type="book thesis report motion_picture" match="any">
        <text variable="title" font-style="italic"/>
      </if>
      <else>
        <text variable="title" prefix="«&#8239;" suffix="&#8239;»"/>
      </else>
    </choose>
  </macro>

  <!-- ========================= -->
  <!-- PAGES -->
  <!-- ========================= -->

  <macro name="pages">
    <choose>
      <if variable="page">
        <group delimiter="">
          <label variable="page" form="short" suffix="&#8239;"/>
          <text variable="page"/>
        </group>
      </if>
    </choose>
  </macro>

  <!-- ========================= -->
  <!-- URL -->
  <!-- ========================= -->

  <macro name="url">
    <choose>
      <if variable="URL">
        <group delimiter=". ">
          <group delimiter=" ">
            <text value="consulté le"/>
            <date variable="accessed" form="text"/>
          </group>
          <group delimiter=" ">
            <text value="URL&#8239;:"/>
            <text variable="URL"/>
          </group>
        </group>
      </if>
    </choose>
  </macro>

  <!-- ========================= -->
  <!-- CITATION -->
  <!-- ========================= -->

  <citation>
    <layout>
      <choose>

        <if position="ibid-with-locator">
          <group delimiter=", ">
            <text term="loc-cit" font-style="italic"/>
            <text macro="pages"/>
          </group>
        </if>

        <else-if position="ibid">
          <text term="ibid" font-style="italic"/>
        </else-if>

        <else-if position="subsequent">
          <group delimiter=", ">
            <text macro="author-note"/>
            <text term="cited" font-style="italic"/>
            <text macro="pages"/>
          </group>
        </else-if>

        <else>
          <group delimiter=", ">
            <text macro="author-note"/>
            <text macro="title"/>
            <text macro="year"/>
            <text macro="pages"/>
            <text macro="url"/>
          </group>
        </else>

      </choose>
    </layout>
  </citation>

  <!-- ========================= -->
  <!-- BIBLIOGRAPHY -->
  <!-- ========================= -->

  <bibliography>
    <sort>
      <key macro="author-bib"/>
    </sort>

    <layout>

      <choose>

        <!-- ================= BOOK ================= -->
        <if type="book">
          <group delimiter=", " suffix=".">
            <text macro="author-bib"/>
            <text macro="title"/>
            <text variable="publisher-place"/>
            <text variable="publisher"/>
            <text macro="year"/>
          </group>
        </if>

        <!-- ================= ARTICLE ================= -->
        <else-if type="article-journal">
          <group delimiter=", " suffix=".">
            <text macro="author-bib"/>
            <text macro="title"/>
            <text variable="container-title" font-style="italic"/>
            <group delimiter=" ">
              <text value="vol."/>
              <text variable="volume"/>
            </group>
            <group delimiter=" ">
              <text value="n°"/>
              <text variable="issue"/>
            </group>
            <text macro="year"/>
            <text macro="pages"/>
            <text macro="url"/>
          </group>
        </else-if>

        <!-- ================= CHAPTER ================= -->
        <else-if type="chapter">
          <group delimiter=", " suffix=".">
            <text macro="author-bib"/>
            <text macro="title"/>
            <text value="dans"/>
            <names variable="editor">
              <name and="text"/>
              <label form="short" prefix=" (" suffix=")"/>
            </names>
            <text variable="container-title" font-style="italic"/>
            <text variable="publisher-place"/>
            <text variable="publisher"/>
            <text macro="year"/>
            <text macro="pages"/>
          </group>
        </else-if>

        <!-- ================= THESIS ================= -->
        <else-if type="thesis">
          <group delimiter=", " suffix=".">
            <text macro="author-bib"/>
            <text macro="title"/>
            <text variable="genre"/>
            <group>
              <text value="sous la dir. de "/>
              <names variable="director">
                <name and="text"/>
              </names>
            </group>
            <text variable="publisher"/>
            <text macro="year"/>
          </group>
        </else-if>

        <!-- ================= WEB / BLOG ================= -->
        <else-if type="webpage post-weblog">
          <group delimiter=", " suffix=".">
            <text macro="author-bib"/>
            <text macro="title"/>
            <text variable="container-title" font-style="italic"/>
            <text macro="year"/>
            <text macro="url"/>
          </group>
        </else-if>

        <!-- ================= ENCYCLOPEDIA (WIKIPEDIA) ================= -->
        <else-if type="entry-encyclopedia">
          <group delimiter=", " suffix=".">
            <text macro="author-bib"/>
            <text macro="title"/>
            <text variable="container-title" font-style="italic"/>
            <text macro="year"/>
            <text macro="url"/>
          </group>
        </else-if>

        <!-- ================= CONFERENCE ================= -->
        <else-if type="paper-conference">
          <group delimiter=", " suffix=".">
            <text macro="author-bib"/>
            <text macro="title"/>
            <text value="communication présentée à"/>
            <text variable="event"/>
            <text macro="year"/>
            <text macro="url"/>
          </group>
        </else-if>

        <!-- ================= FALLBACK ================= -->
        <else>
          <group delimiter=", " suffix=".">
            <text macro="author-bib"/>
            <text macro="title"/>
            <text macro="year"/>
            <text macro="url"/>
          </group>
        </else>

      </choose>

    </layout>
  </bibliography>

</style>
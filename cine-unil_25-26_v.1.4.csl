<?xml version="1.0" encoding="utf-8"?>
<style xmlns="http://purl.org/net/xbiblio/csl"
       class="note"
       version="1.0"
       default-locale="fr-CH"
       page-range-format="expanded"
       delimiter-precedes-et-al="always"
       delimiter-precedes-last="never"
       et-al-min="5"
       et-al-use-first="3">

  <info>
    <title>UNIL Cinéma – notes et bibliographie (2025-2026 v. 1.4)</title>
    <title-short>UNIL Cinéma</title-short>
    <id>http://www.zotero.org/styles/unil-cinema-notes-biblio-fr-ch</id>
    <link href="http://www.zotero.org/styles/unil-cinema-notes-biblio-fr-ch" rel="self"/>
    <author>
      <name>Assisté par ChatGPT à partir du style d’André J. S. Fonseca</name>
    </author>
    <category citation-format="note"/>
    <category field="history"/>
    <category field="cinema"/>
    <summary>Style notes-bibliographie adapté aux consignes 2025/2026 de la Section d’histoire et esthétique du cinéma de l’UNIL.</summary>
    <updated>2026-03-23T00:00:00+00:00</updated>
    <rights license="http://creativecommons.org/licenses/by-sa/3.0/"/>
  </info>

  <locale xml:lang="fr">
    <terms>
      <term name="editor" form="short">dir.</term>
      <term name="edition" form="short">éd.</term>
      <term name="volume" form="short">vol.</term>
      <term name="issue" form="short">n°</term>
      <term name="page" form="short">p.</term>
      <term name="page" form="short" plural="true">pp.</term>
      <term name="ibid">Idem.</term>
      <term name="loc-cit">Ibid.</term>
      <term name="cited">op. cit.</term>
    </terms>
  </locale>

  <!-- ========================= -->
  <!--         MACROS            -->
  <!-- ========================= -->

  <macro name="author-note">
    <names variable="author">
      <name and="text" delimiter-precedes-last="never" sort-separator=" "/>
      <substitute>
        <names variable="editor"/>
        <names variable="translator"/>
        <names variable="director"/>
        <names variable="interviewer"/>
      </substitute>
    </names>
  </macro>

  <macro name="author-bib">
    <names variable="author">
      <name name-as-sort-order="all" sort-separator=", " and="text" delimiter-precedes-last="never">
        <name-part name="family" text-case="uppercase"/>
      </name>
      <substitute>
        <names variable="editor">
          <name name-as-sort-order="all" sort-separator=", " and="text" delimiter-precedes-last="never">
            <name-part name="family" text-case="uppercase"/>
          </name>
        </names>
        <names variable="translator">
          <name name-as-sort-order="all" sort-separator=", " and="text" delimiter-precedes-last="never">
            <name-part name="family" text-case="uppercase"/>
          </name>
        </names>
        <names variable="director">
          <name name-as-sort-order="all" sort-separator=", " and="text" delimiter-precedes-last="never">
            <name-part name="family" text-case="uppercase"/>
          </name>
        </names>
      </substitute>
    </names>
  </macro>

  <macro name="editor-note">
    <names variable="editor">
      <name and="text" delimiter-precedes-last="never" sort-separator=" "/>
      <label form="short" prefix=" (" suffix=")"/>
    </names>
  </macro>

  <macro name="editor-bib">
    <names variable="editor">
      <name and="text" delimiter-precedes-last="never" name-as-sort-order="all" sort-separator=", ">
        <name-part name="family" text-case="uppercase"/>
      </name>
      <label form="short" prefix=" (" suffix=")"/>
    </names>
  </macro>

  <macro name="translator">
    <names variable="translator" prefix=", trad. ">
      <name and="text" delimiter-precedes-last="never" sort-separator=" "/>
    </names>
  </macro>

  <macro name="issued-year">
    <choose>
      <if variable="issued">
        <date variable="issued">
          <date-part name="year"/>
        </date>
      </if>
      <else>
        <text value="[s.d.]"/>
      </else>
    </choose>
  </macro>

  <macro name="issued-year-only">
    <choose>
      <if variable="issued">
        <date variable="issued">
          <date-part name="year"/>
        </date>
      </if>
      <else>
        <text value="[s.d.]"/>
      </else>
    </choose>
  </macro>

  <macro name="issued-full">
    <choose>
      <if variable="issued">
        <date variable="issued" form="text"/>
      </if>
      <else>
        <text value="[s.d.]"/>
      </else>
    </choose>
  </macro>

  <macro name="original-year">
    <choose>
      <if variable="original-date">
        <date variable="original-date" prefix=" [" suffix="]">
          <date-part name="year"/>
        </date>
      </if>
    </choose>
  </macro>

  <macro name="edition">
    <choose>
      <if variable="edition">
        <choose>
          <if is-numeric="edition">
            <group delimiter=" ">
              <number variable="edition" form="ordinal"/>
              <text term="edition" form="short"/>
            </group>
          </if>
          <else>
            <text variable="edition"/>
          </else>
        </choose>
      </if>
    </choose>
  </macro>

  <macro name="place-publisher">
    <group delimiter=", ">
      <choose>
        <if variable="publisher-place">
          <text variable="publisher-place"/>
        </if>
        <else>
          <text value="[s.l.]"/>
        </else>
      </choose>
      <choose>
        <if variable="publisher">
          <text variable="publisher"/>
        </if>
        <else>
          <text value="[s.n.]"/>
        </else>
      </choose>
    </group>
  </macro>

  <macro name="locator-note">
    <choose>
      <if variable="locator">
        <group delimiter="">
          <label variable="locator" form="short" suffix="&#160;"/>
          <text variable="locator"/>
        </group>
      </if>
    </choose>
  </macro>

  <macro name="pages-bib">
    <choose>
      <if variable="page">
        <group delimiter="">
          <label variable="page" form="short" plural="contextual" suffix="&#160;"/>
          <text variable="page"/>
        </group>
      </if>
    </choose>
  </macro>

  <macro name="collection-title">
    <choose>
      <if variable="collection-title">
        <choose>
          <if variable="collection-number">
            <group prefix=" (" suffix=")" delimiter=", ">
              <group delimiter="">
                <text value="Coll. «&#8239;"/>
                <text variable="collection-title"/>
                <text value="&#8239;»"/>
              </group>
              <group delimiter=" ">
                <text term="issue" form="short"/>
                <text variable="collection-number"/>
              </group>
            </group>
          </if>
          <else>
            <group prefix=" (" suffix=")">
              <text value="Coll. «&#8239;"/>
              <text variable="collection-title"/>
              <text value="&#8239;»"/>
            </group>
          </else>
        </choose>
      </if>
    </choose>
  </macro>

  <macro name="title-main">
    <choose>
      <if type="book thesis report motion_picture graphic manuscript" match="any">
        <text variable="title" font-style="italic"/>
      </if>
      <else-if type="chapter entry-dictionary entry-encyclopedia paper-conference article-journal article-magazine article-newspaper webpage post-weblog interview" match="any">
        <text variable="title" prefix="«&#8239;" suffix="&#8239;»"/>
      </else-if>
      <else-if type="broadcast" match="any">
        <choose>
          <if variable="container-title">
            <text variable="title" prefix="«&#8239;" suffix="&#8239;»"/>
          </if>
          <else>
            <text variable="title" font-style="italic"/>
          </else>
        </choose>
      </else-if>
      <else>
        <text variable="title" font-style="italic"/>
      </else>
    </choose>
  </macro>

  <macro name="container-chapter-note">
    <group delimiter="">
      <text value="dans "/>
      <choose>
        <if variable="editor">
          <text macro="editor-note" suffix=", "/>
        </if>
      </choose>
      <text variable="container-title" font-style="italic"/>
    </group>
  </macro>

  <macro name="container-chapter-bib">
    <group delimiter="">
      <text value="dans "/>
      <choose>
        <if variable="editor">
          <text macro="editor-note" suffix=", "/>
        </if>
      </choose>
      <text variable="container-title" font-style="italic"/>
    </group>
  </macro>

  <macro name="journal-note">
    <group delimiter=", ">
      <text variable="container-title" font-style="italic"/>
      <choose>
        <if variable="volume">
          <group delimiter=" ">
            <text term="volume" form="short"/>
            <text variable="volume"/>
          </group>
        </if>
      </choose>
      <choose>
        <if variable="issue">
          <group delimiter=" ">
            <text term="issue" form="short"/>
            <text variable="issue"/>
          </group>
        </if>
      </choose>
      <choose>
        <if variable="collection-title">
          <group delimiter="">
            <text value="(«&#8239;"/>
            <text variable="collection-title"/>
            <text value="&#8239;»"/>
            <choose>
              <if variable="editor">
                <text value=", dir. "/>
                <names variable="editor">
                  <name and="text" delimiter-precedes-last="never" sort-separator=" "/>
                </names>
              </if>
            </choose>
            <text value=")"/>
          </group>
        </if>
      </choose>
      <text macro="issued-year-only"/>
    </group>
  </macro>

  <macro name="journal-bib">
    <group delimiter=", ">
      <text variable="container-title" font-style="italic"/>
      <choose>
        <if variable="volume">
          <group delimiter=" ">
            <text term="volume" form="short"/>
            <text variable="volume"/>
          </group>
        </if>
      </choose>
      <choose>
        <if variable="issue">
          <group delimiter=" ">
            <text term="issue" form="short"/>
            <text variable="issue"/>
          </group>
        </if>
      </choose>
      <choose>
        <if variable="collection-title">
          <group delimiter="">
            <text value="(«&#8239;"/>
            <text variable="collection-title"/>
            <text value="&#8239;»"/>
            <choose>
              <if variable="editor">
                <text value=", dir. "/>
                <names variable="editor">
                  <name and="text" delimiter-precedes-last="never" sort-separator=" "/>
                </names>
              </if>
            </choose>
            <text value=")"/>
          </group>
        </if>
      </choose>
      <text macro="issued-year-only"/>
    </group>
  </macro>

  <macro name="access-and-url">
    <choose>

      <!-- DOI first -->
      <if variable="DOI">
        <group delimiter=". ">
          <choose>
            <if variable="accessed">
              <group delimiter=" ">
                <text value="consulté le"/>
                <date variable="accessed" form="text"/>
              </group>
            </if>
          </choose>
          <group delimiter=" ">
            <text value="URL&#160;:"/>
            <text variable="DOI" prefix="https://doi.org/"/>
          </group>
        </group>
      </if>

      <!-- THEN URL -->
      <else-if variable="URL">
        <group delimiter=". ">
          <choose>
            <if variable="accessed">
              <group delimiter=" ">
                <text value="consulté le"/>
                <date variable="accessed" form="text"/>
              </group>
            </if>
          </choose>
          <group delimiter=" ">
            <text value="URL&#160;:"/>
            <text variable="URL"/>
          </group>
        </group>
      </else-if>

    </choose>
  </macro>

  <macro name="thesis-note">
    <group delimiter=", ">
      <text variable="title" prefix="«&#8239;" suffix="&#8239;»"/>
      <choose>
        <if variable="genre">
          <text variable="genre"/>
        </if>
        <else>
          <text value="thèse"/>
        </else>
      </choose>
      <choose>
        <if variable="director">
          <group delimiter="">
            <text value="sous la dir. de "/>
            <names variable="director">
              <name and="text" delimiter-precedes-last="never" sort-separator=" "/>
            </names>
          </group>
        </if>
      </choose>
      <text variable="publisher"/>
      <text macro="issued-year"/>
    </group>
  </macro>

  <macro name="thesis-bib">
    <group delimiter=", ">
      <text variable="title" prefix="«&#8239;" suffix="&#8239;»"/>
      <choose>
        <if variable="genre">
          <text variable="genre"/>
        </if>
        <else>
          <text value="thèse"/>
        </else>
      </choose>
      <choose>
        <if variable="director">
          <group delimiter="">
            <text value="sous la dir. de "/>
            <names variable="director">
              <name and="text" delimiter-precedes-last="never" sort-separator=" "/>
            </names>
          </group>
        </if>
      </choose>
      <text variable="publisher"/>
      <text macro="issued-year"/>
    </group>
  </macro>

  <macro name="film-note">
    <group delimiter=", ">
      <text variable="title" font-style="italic"/>
      <choose>
        <if variable="original-title">
          <text variable="original-title" font-style="italic"/>
        </if>
      </choose>
      <names variable="director">
        <name and="text" delimiter-precedes-last="never" sort-separator=" "/>
      </names>
      <text macro="issued-year"/>
    </group>
  </macro>

  <macro name="broadcast-note">
    <group delimiter=", ">
      <choose>
        <if variable="director">
          <names variable="director">
            <name and="text" delimiter-precedes-last="never" sort-separator=" "/>
          </names>
        </if>
      </choose>
      <choose>
        <if variable="title">
          <text variable="title" prefix="«&#8239;" suffix="&#8239;»"/>
        </if>
      </choose>
      <text variable="container-title" font-style="italic"/>
      <choose>
        <if variable="producer">
          <group delimiter="">
            <text value="produit par "/>
            <names variable="producer">
              <name and="text" delimiter-precedes-last="never" sort-separator=" "/>
            </names>
          </group>
        </if>
      </choose>
      <text macro="issued-full"/>
      <text variable="publisher"/>
    </group>
  </macro>

  <macro name="site-title">
    <choose>
      <if variable="container-title">
        <text variable="container-title" font-style="italic"/>
      </if>
      <else-if variable="publisher">
        <text variable="publisher" font-style="italic"/>
      </else-if>
    </choose>
  </macro>

  <macro name="entry-note">
    <group delimiter=", ">
      <choose>
        <if variable="author">
          <text macro="author-note"/>
        </if>
      </choose>
      <text macro="title-main"/>
      <text macro="site-title"/>
      <text macro="issued-year"/>
      <text macro="access-and-url"/>
    </group>
  </macro>

  <macro name="entry-bib">
    <group delimiter=", ">
      <choose>
        <if variable="author">
          <text macro="author-bib"/>
        </if>
      </choose>
      <text macro="title-main"/>
      <text macro="site-title"/>
      <text macro="issued-year"/>
      <text macro="access-and-url"/>
    </group>
  </macro>

  <macro name="web-note">
    <group delimiter=", ">
      <choose>
        <if variable="author">
          <text macro="author-note"/>
        </if>
      </choose>
      <text macro="title-main"/>
      <text macro="site-title"/>
      <text macro="issued-full"/>
      <text macro="access-and-url"/>
    </group>
  </macro>

  <macro name="web-bib">
    <group delimiter=", ">
      <choose>
        <if variable="author">
          <text macro="author-bib"/>
        </if>
      </choose>
      <text macro="title-main"/>
      <text macro="site-title"/>
      <text macro="issued-full"/>
      <text macro="access-and-url"/>
    </group>
  </macro>

  <macro name="conference-note">
    <group delimiter=", ">
      <text macro="author-note"/>
      <text macro="title-main"/>
      <choose>
        <if variable="genre">
          <text variable="genre"/>
        </if>
        <else>
          <text value="communication"/>
        </else>
      </choose>
      <choose>
        <if variable="event">
          <text variable="event"/>
        </if>
      </choose>
      <choose>
        <if variable="publisher-place">
          <text variable="publisher-place"/>
        </if>
      </choose>
      <text macro="issued-year"/>
      <text macro="access-and-url"/>
      <text macro="locator-note"/>
    </group>
  </macro>

  <macro name="conference-bib">
    <group delimiter=", ">
      <text macro="author-bib"/>
      <text macro="title-main"/>
      <choose>
        <if variable="genre">
          <text variable="genre"/>
        </if>
        <else>
          <text value="communication"/>
        </else>
      </choose>
      <choose>
        <if variable="event">
          <text variable="event"/>
        </if>
      </choose>
      <choose>
        <if variable="publisher-place">
          <text variable="publisher-place"/>
        </if>
      </choose>
      <text macro="issued-year"/>
      <text macro="access-and-url"/>
    </group>
  </macro>

  <!-- ========================= -->
  <!--         CITATION          -->
  <!-- ========================= -->

  <citation et-al-min="5" et-al-use-first="3">
    <layout>
      <choose>

        <if position="ibid-with-locator">
          <group delimiter=", ">
            <text term="loc-cit" font-style="italic"/>
            <text macro="locator-note"/>
          </group>
        </if>

        <else-if position="ibid">
          <text term="ibid" font-style="italic"/>
        </else-if>

        <else-if position="subsequent">
          <group delimiter=", " suffix=".">
            <text macro="author-note"/>
            <choose>
              <if type="article-journal article-magazine article-newspaper chapter entry-dictionary entry-encyclopedia interview webpage post-weblog paper-conference" match="any">
                <text value="art. cit." font-style="italic"/>
              </if>
              <else>
                <text term="cited" font-style="italic"/>
              </else>
            </choose>
            <text macro="locator-note"/>
          </group>
        </else-if>

        <else>
          <choose>

            <if type="book" match="any">
              <group delimiter=", " suffix=".">
                <text macro="author-note"/>
                <text macro="title-main"/>
                <text macro="place-publisher"/>
                <group delimiter="">
                  <text macro="issued-year"/>
                  <text macro="original-year"/>
                </group>
                <text macro="translator"/>
                <text macro="edition"/>
                <text macro="collection-title"/>
                <text macro="locator-note"/>
              </group>
            </if>

            <else-if type="chapter" match="any">
              <group delimiter=", " suffix=".">
                <text macro="author-note"/>
                <text macro="title-main"/>
                <text macro="container-chapter-note"/>
                <text macro="place-publisher"/>
                <group delimiter="">
                  <text macro="issued-year"/>
                  <text macro="original-year"/>
                </group>
                <text macro="locator-note"/>
              </group>
            </else-if>

            <else-if type="entry-dictionary entry-encyclopedia" match="any">
              <group suffix=".">
                <text macro="entry-note"/>
              </group>
            </else-if>

            <else-if type="article-journal article-magazine" match="any">
              <group delimiter=", " suffix=".">
                <text macro="author-note"/>
                <text macro="title-main"/>
                <text macro="journal-note"/>
                <text macro="locator-note"/>
                <text macro="access-and-url"/>
              </group>
            </else-if>

            <else-if type="article-newspaper" match="any">
              <group delimiter=", " suffix=".">
                <text macro="author-note"/>
                <text macro="title-main"/>
                <text variable="container-title" font-style="italic"/>
                <text macro="issued-full"/>
                <text macro="locator-note"/>
                <text macro="access-and-url"/>
              </group>
            </else-if>

            <else-if type="paper-conference" match="any">
              <group delimiter=", " suffix=".">
                <text macro="conference-note"/>
              </group>
            </else-if>

            <else-if type="thesis" match="any">
              <group delimiter=", " suffix=".">
                <text macro="author-note"/>
                <text macro="thesis-note"/>
                <text macro="locator-note"/>
              </group>
            </else-if>

            <else-if type="motion_picture" match="any">
              <group delimiter=", " suffix=".">
                <text macro="film-note"/>
                <text macro="locator-note"/>
              </group>
            </else-if>

            <else-if type="broadcast" match="any">
              <group delimiter=", " suffix=".">
                <text macro="broadcast-note"/>
                <text macro="locator-note"/>
              </group>
            </else-if>

            <else-if type="webpage post-weblog" match="any">
              <group suffix=".">
                <text macro="web-note"/>
              </group>
            </else-if>

            <else>
              <group delimiter=", " suffix=".">
                <text macro="author-note"/>
                <text macro="title-main"/>
                <choose>
                  <if variable="container-title">
                    <text variable="container-title" font-style="italic"/>
                  </if>
                  <else-if variable="publisher">
                    <text variable="publisher" font-style="italic"/>
                  </else-if>
                </choose>
                <group delimiter="">
                  <text macro="issued-year"/>
                  <text macro="original-year"/>
                </group>
                <text macro="locator-note"/>
                <text macro="access-and-url"/>
              </group>
            </else>

          </choose>
        </else>
      </choose>
    </layout>
  </citation>

  <!-- ========================= -->
  <!--       BIBLIOGRAPHY        -->
  <!-- ========================= -->

  <bibliography et-al-min="5" et-al-use-first="3">
    <sort>
      <key macro="author-bib"/>
      <key variable="issued"/>
      <key variable="title"/>
    </sort>
    <layout>
      <choose>

        <if type="book" match="any">
          <group delimiter=", " suffix=".">
            <text macro="author-bib"/>
            <text macro="title-main"/>
            <text macro="place-publisher"/>
            <group delimiter="">
              <text macro="issued-year"/>
              <text macro="original-year"/>
            </group>
            <text macro="translator"/>
            <text macro="edition"/>
            <text macro="collection-title"/>
          </group>
        </if>

        <else-if type="chapter" match="any">
          <group delimiter=", " suffix=".">
            <text macro="author-bib"/>
            <text macro="title-main"/>
            <text macro="container-chapter-bib"/>
            <text macro="place-publisher"/>
            <group delimiter="">
              <text macro="issued-year"/>
              <text macro="original-year"/>
            </group>
            <text macro="pages-bib"/>
          </group>
        </else-if>

        <else-if type="entry-dictionary entry-encyclopedia" match="any">
          <group suffix=".">
            <text macro="entry-bib"/>
          </group>
        </else-if>

        <else-if type="article-journal article-magazine" match="any">
          <group delimiter=", " suffix=".">
            <text macro="author-bib"/>
            <text macro="title-main"/>
            <text macro="journal-bib"/>
            <text macro="pages-bib"/>
            <text macro="access-and-url"/>
          </group>
        </else-if>

        <else-if type="article-newspaper" match="any">
          <group delimiter=", " suffix=".">
            <text macro="author-bib"/>
            <text macro="title-main"/>
            <text variable="container-title" font-style="italic"/>
            <text macro="issued-full"/>
            <text macro="pages-bib"/>
            <text macro="access-and-url"/>
          </group>
        </else-if>

        <else-if type="paper-conference" match="any">
          <group delimiter=", " suffix=".">
            <text macro="conference-bib"/>
          </group>
        </else-if>

        <else-if type="thesis" match="any">
          <group delimiter=", " suffix=".">
            <text macro="author-bib"/>
            <text macro="thesis-bib"/>
          </group>
        </else-if>

        <else-if type="motion_picture" match="any">
          <group delimiter=", " suffix=".">
            <text variable="title" font-style="italic"/>
            <choose>
              <if variable="original-title">
                <text variable="original-title" font-style="italic"/>
              </if>
            </choose>
            <names variable="director">
              <name and="text" delimiter-precedes-last="never" sort-separator=" "/>
            </names>
            <text macro="issued-year"/>
          </group>
        </else-if>

        <else-if type="broadcast" match="any">
          <group delimiter=", " suffix=".">
            <choose>
              <if variable="director">
                <names variable="director">
                  <name name-as-sort-order="all" sort-separator=", " and="text" delimiter-precedes-last="never">
                    <name-part name="family" text-case="uppercase"/>
                  </name>
                </names>
              </if>
            </choose>
            <choose>
              <if variable="title">
                <text variable="title" prefix="«&#8239;" suffix="&#8239;»"/>
              </if>
            </choose>
            <text variable="container-title" font-style="italic"/>
            <choose>
              <if variable="producer">
                <group delimiter="">
                  <text value="produit par "/>
                  <names variable="producer">
                    <name and="text" delimiter-precedes-last="never" sort-separator=" "/>
                  </names>
                </group>
              </if>
            </choose>
            <text macro="issued-full"/>
            <text variable="publisher"/>
          </group>
        </else-if>

        <else-if type="webpage post-weblog" match="any">
          <group suffix=".">
            <text macro="web-bib"/>
          </group>
        </else-if>

        <else>
          <group delimiter=", " suffix=".">
            <text macro="author-bib"/>
            <text macro="title-main"/>
            <choose>
              <if variable="container-title">
                <text variable="container-title" font-style="italic"/>
              </if>
              <else-if variable="publisher">
                <text variable="publisher" font-style="italic"/>
              </else-if>
            </choose>
            <group delimiter="">
              <text macro="issued-year"/>
              <text macro="original-year"/>
            </group>
            <text macro="pages-bib"/>
            <text macro="access-and-url"/>
          </group>
        </else>

      </choose>
    </layout>
  </bibliography>
</style>